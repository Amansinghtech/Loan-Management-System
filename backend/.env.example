# Server
PORT=5000
NODE_ENV=development

# Frontend origin(s) allowed by CORS (cookies require explicit origins, not *).
# Accepts a comma-separated list for production + preview, e.g.
# CLIENT_ORIGIN=https://lendflow.vercel.app,https://lendflow-git-preview.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# MongoDB connection string (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/lms

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Set to true in production (HTTPS). This also switches the auth cookie to
# SameSite=None so it works across the Vercel <-> Render origins.
COOKIE_SECURE=false

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=lms-salary-slips
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Default password used by the seed script for every seeded role account
SEED_PASSWORD=Password@123
