# The browser always calls the Next.js app's own origin under /api. Next then
# proxies those requests to the backend (see next.config.mjs rewrites). This
# keeps the auth cookie first-party with the frontend, so the Edge middleware
# can read it and there are no cross-site cookie/CORS issues in production.
#
# Leave this as /api in every environment.
NEXT_PUBLIC_API_URL=/api

# Origin of the backend API that /api/* is proxied to (server-side only).
# Local:      http://localhost:5000
# Production: https://<your-render-service>.onrender.com
BACKEND_ORIGIN=http://localhost:5000
